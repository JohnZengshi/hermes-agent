# Hermes gateway profiles unified env example
# ==========================================
#
# This file is the canonical reference for the example environment variables used by
# the local gateway profiles under templates/gateway-profiles/*.
#
# Runtime still uses per-profile .env files, for example:
#   templates/gateway-profiles/hermes/.env
#   templates/gateway-profiles/codecraft/.env
#   templates/gateway-profiles/router/.env
#
# Copy only the relevant section into the matching profile .env file.


# -----------------------------------------------------------------------------
# hermes
# File: templates/gateway-profiles/hermes/.env
# 主力 backend（通常 :8643）
# -----------------------------------------------------------------------------

# Hermes 网关对外鉴权密钥（调用 :8643 /v1/* 时作为 Bearer token）
API_KEY=

# 第三方 OpenAI 兼容服务的基础地址（建议包含 /v1）
# 示例: https://api.vectortara.com/v1
CODECRAFT_BASE_URL=

# 第三方 OpenAI 兼容服务的 API Key（上游模型实际调用使用）
THIRD_PARTY_API_KEY=

# 备用：opencode-go 提供商 API Key（当前 custom provider 模式通常不使用）
OPENCODE_GO_API_KEY=

# 调试开关：是否在 sessions/ 下输出上游请求 dump（排障用）
# true: 开启  false: 关闭
HERMES_DUMP_REQUESTS=true

# 网关授权开关：true 表示允许所有用户访问（仅建议本地/内网测试）
GATEWAY_ALLOW_ALL_USERS=

# Telegram Bot Token（启用 Telegram 平台时必填）
TELEGRAM_BOT_TOKEN=


# -----------------------------------------------------------------------------
