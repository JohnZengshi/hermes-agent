# Hermes 网关画像统一环境变量示例
# ==================================
#
# 这个文件是 templates/gateway-profiles/* 下各个本地网关画像使用的统一环境变量参考。
#
# 实际运行时，仍然建议按画像分别维护各自的 .env 文件，例如：
#   templates/gateway-profiles/hermes/.env
#   templates/gateway-profiles/codecraft/.env
#   templates/gateway-profiles/router/.env
#
# 使用方式：只复制你需要的那一段到对应画像的 .env 文件中即可。


# -----------------------------------------------------------------------------
# hermes
# 对应文件：templates/gateway-profiles/hermes/.env
# 主力 backend（通常 :8643）
# -----------------------------------------------------------------------------

# Hermes 网关对外鉴权密钥（调用 :8643 /v1/* 时作为 Bearer 令牌）
API_KEY=

# 第三方 OpenAI 兼容服务的基础地址（建议包含 /v1）
# 示例：https://api.vectortara.com/v1
THIRD_PARTY_BASE_URL=

# 第三方 OpenAI 兼容服务的密钥（上游模型实际调用使用）
THIRD_PARTY_API_KEY=

# 备用：opencode-go 提供商密钥（当前自定义提供商模式通常不使用）
OPENCODE_GO_API_KEY=

# 调试开关：是否在 sessions/ 下输出上游请求 dump（排障用）
# true：开启；false：关闭
HERMES_DUMP_REQUESTS=true

# 网关授权开关：true 表示允许所有用户访问（仅建议本地/内网测试）
GATEWAY_ALLOW_ALL_USERS=

# Telegram Bot Token（启用 Telegram 平台时必填）
TELEGRAM_BOT_TOKEN=


# -----------------------------------------------------------------------------
# doubao
# 对应文件：templates/gateway-profiles/doubao/.env
# 豆包后端（通常 :8644）
# -----------------------------------------------------------------------------

# Doubao 网关对外鉴权密钥（调用 :8644 /v1/* 时作为 Bearer 令牌）
API_KEY=

# 第三方 OpenAI 兼容服务的基础地址（建议包含 /v1）
# 示例：https://api.vectortara.com/v1
THIRD_PARTY_BASE_URL=

# 第三方 OpenAI 兼容服务的密钥（上游模型实际调用使用）
THIRD_PARTY_API_KEY=

# 备用：opencode-go 提供商密钥（当前自定义提供商模式通常不使用）
OPENCODE_GO_API_KEY=

# 调试开关：是否在 sessions/ 下输出上游请求 dump（排障用）
# true：开启；false：关闭
HERMES_DUMP_REQUESTS=true

# 网关授权开关：true 表示允许所有用户访问（仅建议本地/内网测试）
GATEWAY_ALLOW_ALL_USERS=

# Telegram Bot Token（启用 Telegram 平台时必填）
TELEGRAM_BOT_TOKEN=


# -----------------------------------------------------------------------------
# codecraft
# 对应文件：templates/gateway-profiles/codecraft/.env
# 代码匠后端（通常 :8646）
# -----------------------------------------------------------------------------

# CodeCraft 网关对外鉴权密钥（调用 :8646 /v1/* 时作为 Bearer 令牌）
API_KEY=

# Telegram Bot Token（启用 Telegram 平台时必填）
TELEGRAM_BOT_TOKEN=

# 群消息触发策略（建议与 config.yaml 保持一致）
# true：仅在 @bot / 回复 bot / 命令 时触发；false：群里可直接触发
TELEGRAM_REQUIRE_MENTION=true

# 允许“全量自动回复”的群 chat_id 列表（逗号分隔）
# 为空表示没有白名单群，避免每条群消息都触发
TELEGRAM_FREE_RESPONSE_CHATS=

# 第三方 OpenAI 兼容服务的基础地址（建议包含 /v1）
# 示例：http://127.0.0.1:8317/v1
THIRD_PARTY_BASE_URL=

# 第三方 OpenAI 兼容服务的密钥（上游模型实际调用使用）
THIRD_PARTY_API_KEY=

# 备用：opencode-go 提供商密钥（当前自定义提供商模式通常不使用）
OPENCODE_GO_API_KEY=

# 调试开关：是否在 sessions/ 下输出上游请求 dump（排障用）
# true：开启；false：关闭
HERMES_DUMP_REQUESTS=true

# 网关授权开关：true 表示允许所有用户访问（仅建议本地/内网测试）
GATEWAY_ALLOW_ALL_USERS=

# 可选：允许 /gmem（全局记忆模式）的 owner Telegram user_id
# 示例：8259215216
GLOBAL_MEMORY_OWNER_ID=

# Docker 沙箱工作目录（用于映射 /workspace，可选的部署约定变量）
# 仅在你把 config.yaml 中的挂载路径改为引用该变量时需要设置
HERMES_SANDBOX_WORKSPACE=

# 源码目录（通常用于只读挂载到容器 /src，可选的部署约定变量）
SOURCE_CODE_PATH=

# 如需经代理访问外网，可按需取消下列变量的注释
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=


# -----------------------------------------------------------------------------
# flora
# 对应文件：templates/gateway-profiles/flora/.env
# 小花后端（通常 :8647）
# -----------------------------------------------------------------------------

# Flora 网关对外鉴权密钥（调用 :8647 /v1/* 时作为 Bearer 令牌）
API_KEY=

# 第三方 OpenAI 兼容服务的基础地址（建议包含 /v1）
# 示例：https://api.vectortara.com/v1
THIRD_PARTY_BASE_URL=

# 第三方 OpenAI 兼容服务的密钥（上游模型实际调用使用）
THIRD_PARTY_API_KEY=

# 备用：opencode-go 提供商密钥（当前自定义提供商模式通常不使用）
OPENCODE_GO_API_KEY=

# 调试开关：是否在 sessions/ 下输出上游请求 dump（排障用）
# true：开启；false：关闭
HERMES_DUMP_REQUESTS=true

# 网关授权开关：true 表示允许所有用户访问（仅建议本地/内网测试）
GATEWAY_ALLOW_ALL_USERS=

# Telegram Bot Token（启用 Telegram 平台时必填）
TELEGRAM_BOT_TOKEN=


# -----------------------------------------------------------------------------
# frontmaster
# 对应文件：templates/gateway-profiles/frontmaster/.env
# FrontMaster 后端（通常 :8648）
# -----------------------------------------------------------------------------

# FrontMaster 网关对外鉴权密钥（调用 :8648 /v1/* 时作为 Bearer 令牌）
API_KEY=

# Telegram Bot Token（启用 Telegram 平台时必填）
TELEGRAM_BOT_TOKEN=

# 群消息触发策略（建议与 config.yaml 保持一致）
# true：仅在 @bot / 回复 bot / 命令 时触发；false：群里可直接触发
TELEGRAM_REQUIRE_MENTION=true

# 允许“全量自动回复”的群 chat_id 列表（逗号分隔）
# 为空表示没有白名单群，避免每条群消息都触发
TELEGRAM_FREE_RESPONSE_CHATS=

# 第三方 OpenAI 兼容服务的基础地址（建议包含 /v1）
# 这里使用 frontmaster 专用变量名，与其 config.yaml 保持一致
FRONTMASTER_BASE_URL=

# 第三方 OpenAI 兼容服务的密钥（上游模型实际调用使用）
THIRD_PARTY_API_KEY=

# 备用：opencode-go 提供商密钥（当前自定义提供商模式通常不使用）
OPENCODE_GO_API_KEY=

# 调试开关：是否在 sessions/ 下输出上游请求 dump（排障用）
# true：开启；false：关闭
HERMES_DUMP_REQUESTS=true

# 网关授权开关：true 表示允许所有用户访问（仅建议本地/内网测试）
GATEWAY_ALLOW_ALL_USERS=

# FrontMaster 默认工作空间（代码拉取 / 修改 / 构建默认在这里执行）
# 示例：/Users/littleflower/workspaces/frontmaster
MESSAGING_CWD=

# 可选：限制 agent 可写范围；如果需要最高权限，请保持为空或不要设置
HERMES_WRITE_SAFE_ROOT=


# -----------------------------------------------------------------------------
# reviewpilot
# 对应文件：templates/gateway-profiles/reviewpilot/.env
# 代码审查机器人（通常 :8649，Webhook :8650）
# -----------------------------------------------------------------------------

# ReviewPilot 网关对外鉴权密钥（调用 :8649 /v1/* 时作为 Bearer 令牌）
API_KEY=

# Telegram Bot Token（启用 Telegram 平台时必填）
TELEGRAM_BOT_TOKEN=

# 仅允许这些 TG 用户触发机器人（逗号分隔），默认建议只填创建者 TGID）
# 示例：123456789
TELEGRAM_ALLOWED_USERS=

# 网关全局允许列表（可留空；建议与 TELEGRAM_ALLOWED_USERS 一致）
GATEWAY_ALLOWED_USERS=

# 群消息触发策略（建议与 config.yaml 保持一致）
# true：仅在 @bot / 回复 bot / 命令 时触发；false：群里可直接触发
TELEGRAM_REQUIRE_MENTION=true

# 允许“全量自动回复”的群 chat_id 列表（逗号分隔）
# 为空表示没有白名单群，避免每条群消息都触发
TELEGRAM_FREE_RESPONSE_CHATS=

# 审查推送目标群（多群，逗号分隔；优先使用）
# 示例：-1001234567890,-1009876543210
TELEGRAM_REVIEW_GROUP_IDS=

# 审查推送目标群（单群兼容变量）
TELEGRAM_REVIEW_GROUP_ID=

# 审查推送目标话题（可选，论坛群主题编号）
TELEGRAM_REVIEW_THREAD_ID=

# Webhook 全局签名密钥（启用 webhook 触发时必填）
WEBHOOK_GLOBAL_SECRET=

# review-git-push 路由专用签名密钥（启用 webhook 触发时必填）
REVIEW_PUSH_ROUTE_SECRET=

# 审查消息中的 @ 提醒对象（纯文本，按你群里格式填写）
# 示例：@alice @bob
REVIEW_MENTION_HANDLES=

# 可选：允许 /gmem（全局记忆模式）的 owner Telegram user_id
# 示例：8259215216
GLOBAL_MEMORY_OWNER_ID=

# 自定义服务商 CPAMC（model.provider=custom 时使用）
CPAMC_BASE_URL=http://10.0.0.154:8317/v1
CPAMC_API_KEY=

# 运行工作目录（建议使用临时目录）
MESSAGING_CWD=/tmp/reviewpilot-remote
TERMINAL_CWD=/tmp/reviewpilot-remote

# review 技能使用的 Git 凭据（仅在需要拉取私有仓库时配置）
REVIEW_GIT_USERNAME=
REVIEW_GIT_PASSWORD=

# 可选：自定义 askpass 脚本路径；大多数场景不需要手动设置
GIT_ASKPASS=


# -----------------------------------------------------------------------------
# router
# 对应文件：templates/gateway-profiles/router/.env
# 智能路由（通常 :8645）
# -----------------------------------------------------------------------------

# Router 网关对外鉴权密钥（调用 :8645 /v1/* 时作为 Bearer 令牌）
ROUTER_API_KEY=

# 下游后端鉴权密钥（必须与各后端画像的 API_KEY 保持一致）
# 对应 hermes-agent 后端（通常是 :8643）
HERMES_BACKEND_API_KEY=

# 对应 doubao-agent 后端（通常是 :8644）
DOUBAO_BACKEND_API_KEY=

# 对应 codecraft-agent 后端（通常是 :8646）
CODECRAFT_BACKEND_API_KEY=

# 对应 flora-agent 后端（通常是 :8647）
FLORA_BACKEND_API_KEY=

# 对应 frontmaster-agent 后端（通常是 :8648）
FRONTMASTER_BACKEND_API_KEY=

# 对应 reviewpilot-agent 后端（通常是 :8649）
REVIEWPILOT_BACKEND_API_KEY=
