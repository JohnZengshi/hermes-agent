# Hermes 网关对外鉴权密钥（调用 :8647 /v1/* 时作为 Bearer token）
API_KEY=

# 第三方 OpenAI 兼容服务的基础地址（建议包含 /v1）
# 示例: https://api.vectortara.com/v1
FRONTMASTER_BASE_URL=

# 第三方 OpenAI 兼容服务的 API Key（上游模型实际调用使用）
THIRD_PARTY_API_KEY=

# 备用：opencode-go 提供商 API Key（当前 custom provider 模式通常不使用）
OPENCODE_GO_API_KEY=

# 调试开关：是否在 sessions/ 下输出上游请求 dump（排障用）
# true: 开启  false: 关闭
HERMES_DUMP_REQUESTS=true

# 网关授权开关：true 表示允许所有用户访问（仅建议本地/内网测试）
GATEWAY_ALLOW_ALL_USERS=

# Telegram Bot Token（启用 Telegram 平台时必填）
TELEGRAM_BOT_TOKEN=

# 群消息触发策略（建议与 config.yaml 保持一致）
# true: 仅在 @bot / 回复 bot / 命令 时触发；false: 群里可直接触发
TELEGRAM_REQUIRE_MENTION=true

# 允许“全量自动回复”的群 chat_id 列表（逗号分隔）
# 为空表示没有白名单群，避免每条群消息都触发
TELEGRAM_FREE_RESPONSE_CHATS=
