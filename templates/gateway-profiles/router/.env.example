# Router 网关对外鉴权密钥（调用 :8645 /v1/* 时作为 Bearer token）
ROUTER_API_KEY=

# 下游 backend 鉴权密钥（必须与各 backend profile 的 API_KEY 保持一致）
# 对应 hermes-agent backend（通常是 :8643）
HERMES_BACKEND_API_KEY=

# 对应 doubao-agent backend（通常是 :8644）
DOUBAO_BACKEND_API_KEY=

# 对应 codecraft-agent backend（通常是 :8646）
CODECRAFT_BACKEND_API_KEY=

# 对应 flora-agent backend（通常是 :8647）
FLORA_BACKEND_API_KEY=
